{% set card_classes = [
  'card',
  'card--' ~ variant,
  'card--' ~ size,
  'card--no-link',
] %}

<div {{ attributes.addClass(card_classes).setAttribute('data-component', 'card') }}>

  {{ group }}
  <div class="card__image">
    {% if image|render %}
      {{ image }}
    {% else %}
      <img src="{{ file_url('/themes/custom/wateraid/images/png/card-fallback.webp') }}" alt=""/>
    {% endif %}
  </div>

  <div class="card__body">
    <div class="card__bundle">
      {{ bundle }}
    </div>
    <h3 class="card__heading">
      {{ heading }}
    </h3>

    {% if date %}
      <div class="card__date">
        {{ include('@wateraid/images/icons/wa-utility-calendar.svg') }}
        {% if group == 'ウォーターエイド｜水・衛生専門の国際NGO' %}
          {{ date|date("Y年n月j日") }}
          {% if end_date and (date|date("Y年n月j日") != end_date|date("Y年n月j日")) %}
            - {{ end_date|date("Y年n月j日") }}
          {% endif %}
        {% else %}
          {{ date|date("j F Y") }}
          {% if end_date and (date|date("j F Y") != end_date|date("j F Y")) %}
            - {{ end_date|date("j F Y") }}
          {% endif %}
        {% endif %}
      </div>
    {% endif %}

    {% if authors %}
      <div class="card__authors">
        {{ include('@wateraid/images/icons/wa-utility-person.svg') }}
        {% if authors|length <= 2 %}
          {{ authors.0 }}
          {% if authors|length == 2 %}
            , {{ authors.1 }}
          {% endif %}
        {% else %}
          {{ authors|length ~ ' authors'|t }}
        {% endif %}
      </div>
    {% endif %}

    {% if time_to_read %}
      <div class="card__read-time">
        {{ include('@wateraid/images/icons/wa-utility-schedule.svg') }}
        {{ time_to_read }}{{ ' min read'|t }}
      </div>
    {% endif %}

    <div class="card__description">
      {{ description }}
    </div>
  </div>
</div>
