{#
/**
 * @file
 * The views infinite scroll pager template.
 */
#}

{% if items.next %}
<ul{{ attributes }}>
  <li class="pager__item">
    {{ include('wateraid:button', {
      text: options.button_text,
      link:  items.next.href,
      type: 'secondary',
      theme: 'light',
      icon: 'wa-utility-plus',
      icon_position: 'before'
    }) }}

  </li>
</ul>
{% endif %}
